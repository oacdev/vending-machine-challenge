{
    "name": "challenge/vending-machine",
    "description": "Vending machine modelled with DDD and hexagonal architecture",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "deptrac/deptrac": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "VendingMachine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VendingMachine\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-cs-fixer/shim": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "deptrac": "deptrac analyse",
        "qa": [
            "@cs-check",
            "@analyse",
            "@deptrac",
            "@test"
        ]
    }
}
